# Database — SQLite for dev, PostgreSQL for production
DATABASE_URL="file:./dev.db"

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# DeepSeek API key for chatbot (https://platform.deepseek.com)
DEEPSEEK_API_KEY=""

# Cloudbeds API keys (per property — https://hotels.cloudbeds.com)
CB_KEY_DARLING=""
CB_KEY_CENTRAL=""
CB_KEY_SURRY=""
CB_KEY_POTTS=""
CB_KEY_PYRMONT=""

# Optional: Property Secrets Encryption Key (for secure credential storage)
PROPERTY_SECRETS_ENCRYPTION_KEY=""
